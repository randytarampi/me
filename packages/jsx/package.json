    "redux-actions": "^3.0.3",
    "redux-devtools-extension": "^2.13.9",
    "redux-first-history": "^5",
    "redux-immutable": "^4.0.0",
    "redux-persist": "^6.0.0",
    "redux-raven-middleware": "^1.2.0",
