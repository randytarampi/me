  },
  "browser": "./esm/index.client.js",
  "bugs": "https://github.com/randytarampi/me/issues",
  "dependencies": {
    "@actra-development-oss/redux-persist-transform-filter-immutable": "^1.0.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
