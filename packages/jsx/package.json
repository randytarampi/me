    "@types/markerclustererplus": "^2.1.33",
    "@types/react": "^19.2.17",
    "classnames": "^2.5.1",
    "history": "^5.3.0",
    "immutable": "^5.1.7",
    "is-html": "^3.2.0",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "materialize-css": "^1.0.0",
    "prop-types": "^15.8.1",
    "query-string": "^9.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-google-maps": "^9.4.5",
    "react-infinite": "^0.13.0",
    "react-materialize": "^3.10.0",
